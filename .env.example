# Copy to .env and fill secrets
OPENAI_API_KEY=
GENERATION_MODEL=gpt-5.4-mini
REASONING_EFFORT=high
CONFIDENCE_MODE=strict
TABLE_LOOKUP_MODE=strict
STRICT_LOOKUP_FAIL_MESSAGE=Exact answer not found in indexed content. Re-ingest and verify query terms.
DEFAULT_TOP_K=5
EMBEDDING_MODEL_NAME=text-embedding-3-large
EMBEDDING_DIMENSION=1024
EMBEDDING_REQUEST_TIMEOUT_SEC=20
CHUNK_DENSITY_MULTIPLIER=10
VECTOR_BACKEND=pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=rag-docs
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE_MODE=single
PINECONE_NAMESPACE=default
